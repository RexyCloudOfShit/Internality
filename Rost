local OldNextStep = RecoilHandler.nextStep

RecoilHandler.nextStep = function(...)
    if Settings.GunMods.NoRecoil then
        return
    end

    return OldNextStep(...)
end

OldNamecall = hookmetamethod(game,"__namecall",function(self,...) 
    local Method = getnamecallmethod()

    if Method == "FireServer" then 
        local Args = {...}

        if self.Name == "Hit" then
            local Tool = Args[1]
            local HitPos = Args[3]
            local HitPart = Args[2]

            if Tool and HitPos then
                if Settings.BulletTracer.Enabled then
                    local HitPos = Args[3]
                    local Origin = Args[1].FireOrigin.Position

                    task.spawn(CreateTracer,Origin,HitPos)
                end
            end

            if HitPart then
                local Model = HitPart.FindFirstAncestorWhichIsA(HitPart,"Model")

                if Model then
                    local Target = Players.GetPlayerFromCharacter(Players,Model)

                    if Target then
                        if Settings.HitSound.Enabled then
                            task.spawn(function()
                                local Sound = Instance.new("Sound",workspace)
                                Sound.Volume = Settings.HitSound.Volume
                                Sound.SoundId = Settings.HitSound.Sound
                                Sound:Play()
                            end)
                        end

                        if Settings.HitNotification.Enabled then
                            task.spawn(Notify.Fire,Notify,"U hit "..Target.Name.." on the "..HitPart.Name,5)
                        end
                    end
                end
            end
        end
    end

    if Method == "Raycast" and Settings.SilentAim.Enabled then
        if getcallingscript() == GunClientCreator then
            local Args = {...}
            local HitPart = Settings.SilentAim.HitPart
            local Target = GetFovTarget(FovCircle,HitPart)
    
            if Target then
                Args[2] = Target.Character[HitPart].Position - Args[1]
            end
    
            return OldNamecall(self,unpack(Args)) 
        end
    end

    return OldNamecall(self,...)
end)

