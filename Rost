local function CreateTracer(From,To)
    local Part1 = Instance.new("Part",Bullets)
    Part1.Anchored = true
    Part1.Position = From
    Part1.Transparency = 1
    Part1.CanCollide = false

    local Part2 = Instance.new("Part",Bullets)
    Part2.Anchored = true
    Part2.Position = To
    Part2.Transparency = 1
    Part2.CanCollide = false

    local Attach1 = Instance.new("Attachment",Part1)
    local Attach2 = Instance.new("Attachment",Part2)
    local Beam = Instance.new("Beam",Bullets)

    Beam.Attachment0 = Attach1
    Beam.Attachment1 = Attach2
    Beam.Texture = "http://www.roblox.com/asset/?id=446111271"
    Beam.Color = ColorSequence.new(Settings.BulletTracer.Color)
    Beam.Width0 = 1
    Beam.Width1 = 1
    Beam.FaceCamera = true

    task.wait(Settings.BulletTracer.Time)
    Part1:Destroy()
    Part2:Destroy()
    Beam:Destroy()
end

local function GetFovTarget(Circle,HitPart)
    local Target
    local LowestDistance = math.huge

    for i,v in pairs(Players.GetPlayers(Players)) do
        local Char = v.Character

        if v ~= Player and Char then
            local Humanoid = Char.FindFirstChild(Char,"Humanoid")
            local Hmrp = Char.FindFirstChild(Char,"HumanoidRootPart")

            if Hmrp and Humanoid and Char.FindFirstChild(Char,HitPart) then
                local ScreenPos,OnScreen = Camera.WorldToViewportPoint(Camera,Hmrp.Position)
                local Distance = (Circle.Position - Vector2.new(ScreenPos.X,ScreenPos.Y)).Magnitude

                if Humanoid.Health <= 0 then
                    continue
                end

                if Distance < Circle.Radius and Distance < LowestDistance and OnScreen then
                    Target = v
                    LowestDistance = Distance
                end
            end
        end
    end

    return Target
end

